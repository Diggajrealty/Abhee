RewriteEngine On

# 1. 301 Redirect from the old URL to the new URL (prevents infinite loop by checking if it's the direct request)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^abhee-new-dimension(\.html)?$ /abhee-codename-new-dimension [R=301,L]

# 2. Internally route the new slug to the existing file (if the file isn't physically renamed yet)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^abhee-codename-new-dimension$ abhee-new-dimension.html [L]
